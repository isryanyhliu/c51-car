 212   1        Timer1On;     //ЦєЖЏЖЈЪБЦї1
 213   1        while(EchoPin);   //ЕШД§ЪеЕНЛиЯьаХКХ
 214   1        Timer1Off;      //ЙиБеЖЈЪБЦї1
 215   1        Time=TH1*256+TL1; //ЖСШЁЪБМф
 216   1        TH1=0;
