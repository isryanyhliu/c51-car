 206          unsigned int QXMBOT_GetDistance()
 207          {
 208   1        unsigned int Distance = 0;  //ГЌЩљВЈОрРы
 209   1        unsigned int  Time=0;   //гУгкДцЗХЖЈЪБЦїЪБМфжЕ
 210   1        QXMBOT_TrigUltrasonic();  //ГЌЩљВЈДЅЗЂ
